# Hasura GraphQL endpoint (from Hasura Cloud console)
VITE_HASURA_GRAPHQL_URL=https://your-project.hasura.app/v1/graphql

# Hasura admin secret (optional, for mutations from frontend — NOT for production)
VITE_HASURA_ADMIN_SECRET=

# For import script (not prefixed with VITE_ — server-side only)
HASURA_GRAPHQL_URL=https://your-project.hasura.app/v1/graphql
HASURA_ADMIN_SECRET=your-admin-secret
