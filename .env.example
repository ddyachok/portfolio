# Hasura GraphQL endpoint (from Hasura Cloud console)
# Public read access via anonymous role — no secret needed
VITE_HASURA_GRAPHQL_URL=https://your-project.hasura.app/v1/graphql

# For import script and Vercel API route (server-side only, no VITE_ prefix)
HASURA_GRAPHQL_URL=https://your-project.hasura.app/v1/graphql
HASURA_ADMIN_SECRET=your-admin-secret

# Neon Auth — frontend URL (safe to expose, just a URL)
VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.eu-west-2.aws.neon.tech/neondb/auth

# Neon Auth — server-side base URL for Vercel API route (no VITE_ prefix)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.eu-west-2.aws.neon.tech/neondb/auth

# Cloudinary image hosting (safe to expose, public preset)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
